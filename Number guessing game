#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

int main() {
    int number, guess, attempts = 0;
    const int maxAttempts = 4;

 
    srand(time(0));
    number = rand() % 100 + 1;

    cout << " Welcome to Number Guessing Game!" << endl;
    cout << "Guess a number between 1 and 100" << endl;
    cout << "You have only 4 chances!" << endl;

    while (attempts < maxAttempts) {
        cout << "Enter your guess: ";
        cin >> guess;

    
        if (guess > 100) {
            cout << "❌ Invalid number! Please enter a number between 1 and 100.\n";
            continue; 
        }

        attempts++;

        if (guess > number) {
            cout << "Too high! Try again.\n";
        }
        else if (guess < number) {
            cout << "Too low! Try again.\n";
        }
        else {
            cout << "🎉 Correct! You guessed it in " << attempts << " attempts.\n";
            return 0;
        }

        cout << "Remaining attempts: " << (maxAttempts - attempts) << endl;
    }

    cout << "❌ Game Over! The correct number was: " << number << endl;

    return 0;
}
